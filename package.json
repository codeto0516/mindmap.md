{
  "name": "mindmap-md",
  "version": "0.1.0",
  "private": true,
  "displayName": "mindmap.md",
  "description": "マークダウンをマインドマップとして編集するエディタ",
  "publisher": "mindmap-md",
  "repository": { "type": "git", "url": "" },
  "engines": { "vscode": "^1.85.0" },
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "mindmap.md.markdown",
        "displayName": "マインドマップ",
        "selector": [{ "filenamePattern": "*.md" }],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "mindmap-md.openAsMindMap",
        "title": "マインドマップで開く"
      }
    ],
    "menus": {
      "commandPalette": [{ "command": "mindmap-md.openAsMindMap" }],
      "editor/title/context": [
        {
          "command": "mindmap-md.openAsMindMap",
          "when": "resourceLangId == markdown"
        }
      ]
    },
    "configuration": {
      "title": "mindmap.md",
      "properties": {
        "mindmap-md.theme": {
          "type": "string",
          "enum": ["auto", "light", "dark"],
          "default": "auto",
          "description": "マインドマップのテーマ。auto で VSCode のテーマに追従"
        }
      }
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:extension": "node scripts/build-extension.mjs",
    "build:webview": "vite build --config vite.webview.config.ts",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "build:vsix": "pnpm run build:extension && pnpm run build:webview",
    "package:vsix": "pnpm exec vsce package --no-dependencies --baseContentUrl https://github.com/example/mindmap-md/blob/HEAD --baseImagesUrl https://github.com/example/mindmap-md/raw/HEAD",
    "package": "pnpm run build:extension && pnpm run build:webview && vsce package --no-dependencies"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@xyflow/react": "^12.0.0",
    "dagre": "^0.8.5",
    "lucide-react": "^0.563.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.3.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.1",
    "@types/dagre": "^0.7.52",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.0.4",
    "esbuild": "^0.24.0",
    "eslint": "^9",
    "eslint-config-prettier": "^9",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "jsdom": "^23.0.1",
    "prettier": "^3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.0.4",
    "vite": "^6",
    "@vscode/vsce": "^3.2.0"
  }
}
